{
  "name": "wa-commerce-server",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "bun src/dev.ts",
    "dev:api": "bun --watch src/main.ts",
    "start": "bun src/main.ts",
    "worker:cleanup": "bun src/workers/cleanup.main.ts",
    "worker:cleanup:once": "bun src/workers/cleanup.main.ts --once",
    "worker:whatsapp": "bun src/workers/whatsapp.main.ts",
    "test": "bun test",
    "check": "tsc --noEmit",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "bun scripts/migrate-neon-http.ts",
    "db:migrate:pg": "drizzle-kit migrate",
    "db:studio": "drizzle-kit studio"
  },
  "dependencies": {
    "@fastify/cookie": "^11.0.2",
    "@fastify/cors": "^11.1.0",
    "@fastify/helmet": "^13.0.2",
    "@fastify/rate-limit": "^10.3.0",
    "@fastify/websocket": "^11.2.0",
    "@neondatabase/serverless": "^1.1.0",
    "@whiskeysockets/baileys": "^7.0.0-rc13",
    "drizzle-orm": "^0.45.2",
    "fastify": "^5.6.2",
    "pino": "^10.3.1",
    "postgres": "^3.4.9",
    "zod": "^4.1.13"
  },
  "devDependencies": {
    "@electric-sql/pglite": "^0.5.1",
    "@types/bun": "^1.3.4",
    "drizzle-kit": "^0.31.10",
    "typescript": "^5.9.3"
  }
}
